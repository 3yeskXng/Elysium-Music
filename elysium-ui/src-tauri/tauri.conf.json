{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Elysium",
  "version": "0.0.3",
  "identifier": "com.3yeskXng.elysium",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Elysium Music",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../Elysium.ico"
    ]
  }
}